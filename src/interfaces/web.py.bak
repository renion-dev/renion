        raise HTTPException(status_code=404, detail="Hypothesis not found")
    
    metadata = obj.get("metadata", {})
    
    html = f"""
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Hypothesis — RENION</title>
